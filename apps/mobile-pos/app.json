{
  "expo": {
    "name": "Eseller POS",
    "slug": "eseller-pos",
    "version": "1.0.0",
    "scheme": "eseller-pos",
    "orientation": "landscape",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": { "supportsTablet": true, "bundleIdentifier": "mn.eseller.pos", "requireFullScreen": true },
    "android": { "package": "mn.eseller.pos", "adaptiveIcon": { "backgroundColor": "#0A0A0A" } },
    "plugins": ["expo-router", "expo-secure-store", "expo-camera"]
  }
}
