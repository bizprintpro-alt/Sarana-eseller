# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# .env.production.template is intentionally tracked — placeholder-only
# doc that mirrors the full set of env vars expected in Vercel.
!.env.production.template

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma generated
src/generated/

# Debug/seed scripts (break Vercel build)
check*.ts
reset-*.mts
check-*.mts
prisma/*.mts

.vercel

.env*.local
.vercel
