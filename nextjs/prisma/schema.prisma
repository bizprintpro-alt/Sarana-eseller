// ══════════════════════════════════════════════════════════════
// eseller.mn — Prisma Schema (MongoDB)
// ══════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ══════════════════════════════════════════════════════════════
// EXISTING MODELS (migrated from Mongoose)
// ══════════════════════════════════════════════════════════════

type StoreInfo {
  name        String?
  description String?
  logo        String?
  phone       String?
  address     String?
  commission  Int?    @default(15)
}

type AffiliateInfo {
  bio       String?
  avatar    String?
  cover     String?
  verified  Boolean? @default(false)
  followers Int?     @default(0)
}

type BankInfo {
  bankName      String?
  accountNumber String?
  accountName   String?
}

model User {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String    @unique
  password  String
  role      String    @default("buyer") // buyer | seller | affiliate | delivery | admin
  username  String?   @unique
  phone     String?
  avatar    String?
  store     StoreInfo?
  affiliate AffiliateInfo?
  bankInfo  BankInfo?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  entityType String?  // store | agent | company | auto_dealer | service

  // Relations
  products  Product[]
  orders    Order[]
  wallet    Wallet?
  shop      Shop?
  agent     Agent?
  company   Company?
  autoDealer AutoDealer?
  serviceProvider ServiceProvider?
  sellerProfile   SellerProfile?
  partnerAgent    PartnerAgent?

  @@map("users")
}

model Product {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String?  @db.ObjectId
  name          String
  price         Int
  salePrice     Int?
  description   String?
  category      String?
  emoji         String?
  images        String[]
  stock         Int?     @default(0)
  commission    Int?     @default(15)
  rating        Float?
  reviewCount   Int?     @default(0)
  isActive      Boolean  @default(true)
  deliveryFee   Int?
  deliveryType  String   @default("standard") // standard | express | pickup
  estimatedMins Int?
  entityType    String?  // STORE | REAL_ESTATE | AUTO | SERVICE | CONSTRUCTION | PRE_ORDER | DIGITAL
  metadata      Json?    // entity-specific fields

  // Real estate
  area          Float?
  rooms         Int?
  floor         Int?
  totalFloors   Int?
  district      String?

  // Auto
  year          Int?
  mileage       Int?
  fuelType      String?
  transmission  String?
  brand         String?

  // Service
  duration      Int?
  availableSlots Int?

  // Construction
  totalUnits    Int?
  soldUnits     Int?
  completionDate String?
  pricePerSqm   Float?

  // Pre-order
  minBatch      Int?
  currentBatch  Int?
  advancePercent Float?
  deliveryEstimate String?

  // Digital
  fileType      String?
  fileSize      String?
  downloadCount Int?     @default(0)

  allowAffiliate      Boolean @default(false)
  affiliateCommission Float?  @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user            User?           @relation(fields: [userId], references: [id])
  modifierGroups  ModifierGroup[]
  addOns          AddOn[]
  reviews         Review[]
  sellerProducts  SellerProduct[]

  @@map("products")
}

model ModifierGroup {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  productId String           @db.ObjectId
  name      String
  required  Boolean          @default(false)
  multiple  Boolean          @default(false)
  sortOrder Int              @default(0)

  product Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  options ModifierOption[]
}

model ModifierOption {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  groupId   String  @db.ObjectId
  name      String
  price     Int     @default(0)
  available Boolean @default(true)
  sortOrder Int     @default(0)

  group ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model AddOn {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  productId String  @db.ObjectId
  name      String
  price     Int
  image     String?
  available Boolean @default(true)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

type DeliveryAddress {
  district String?
  street   String?
  building String?
}

type DeliveryInfo {
  phone   String?
  address DeliveryAddress?
}

type OrderCommissions {
  affiliate Float?
}

model Order {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  userId       String           @db.ObjectId
  orderNumber  String?
  items        Json[]
  total        Float?
  status           String           @default("pending") // pending | confirmed | preparing | ready | delivering | delivered | cancelled
  referralCode     String?
  delivery         DeliveryInfo?
  commissions      OrderCommissions?
  platformAmount   Int?     @default(0)
  sellerAmount     Int?     @default(0)
  affiliateAmount  Int?     @default(0)
  shopId           String?  @db.ObjectId
  statusHistory    Json[]
  estimatedMinutes Int?
  paymentId        String?          // QPay invoice ID
  paymentMethod    String?          // qpay | card | cash
  deliveryAddress  String?
  sellerProfileId  String?  @db.ObjectId
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("orders")
}

model Wallet {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  balance   Float    @default(0)
  pending   Float    @default(0)
  history   Json[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("wallets")
}

model Commission {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  defaultRate Float @default(15)
  categories  Json?

  @@map("commissions")
}

model AffiliateClick {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  referralCode String
  page         String?
  timestamp    DateTime @default(now())
}

// ══════════════════════════════════════════════════════════════
// NEW MODELS — Service Business Support
// ══════════════════════════════════════════════════════════════

model Shop {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  name      String
  slug      String   @unique
  logo      String?
  phone     String?
  address   String?
  industry  String?
  // Location
  lat           Float?
  lng           Float?
  district      String?  // Дүүрэг: СБД, ЧД, БЗД, ХУД, СХД, БГД, НД
  khoroo        String?  // Хороо: 1-р хороо, 2-р хороо
  locationNote  String?  // Ойролцоох газар
  locationStatus String  @default("pending") // pending | verified | rejected
  locationVerifiedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isBlocked    Boolean  @default(false)
  blockReason  String?

  // Seller/Affiliate permissions
  allowSellers     Boolean @default(false)
  sellerCommission Float   @default(10)   // Default commission % for sellers
  maxSellers       Int?

  // Storefront public page
  storefrontSlug   String?  @unique       // /[slug] public URL
  storefrontConfig Json?                  // Theme, hero, sections config

  user         User               @relation(fields: [userId], references: [id])
  shopType     ShopType?
  services     Service[]
  bookings     Booking[]
  shopDomain   ShopDomain?
  workingHours WorkingHours[]
  storefront   SellerStorefront?
  subscription ShopSubscription?

  @@map("stores")
}

model ShopType {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  shopId String @unique @db.ObjectId
  type   String // "product" | "service" | "hybrid"

  shop Shop @relation(fields: [shopId], references: [id])
}

model Service {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  shopId      String   @db.ObjectId
  name        String
  description String?
  price       Int
  duration    Int?     // minutes
  category    String?
  images      String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop     Shop      @relation(fields: [shopId], references: [id])
  bookings Booking[]
}

model Booking {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  serviceId     String   @db.ObjectId
  shopId        String   @db.ObjectId
  customerId    String?  @db.ObjectId
  customerName  String
  customerPhone String
  scheduledAt   DateTime
  duration      Int?     // minutes — copied from service at booking time
  status        String   @default("pending") // pending | confirmed | in_progress | completed | cancelled | no_show
  notes         String?
  total         Int?
  createdAt     DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id])
  shop    Shop    @relation(fields: [shopId], references: [id])
}

model ShopDomain {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  shopId    String   @unique @db.ObjectId
  domain    String   @unique // e.g. "hairsalon.mn"
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id])
}

model WorkingHours {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  shopId    String  @db.ObjectId
  dayOfWeek Int     // 0=Sun, 1=Mon ... 6=Sat
  openTime  String  // "09:00"
  closeTime String  // "18:00"
  isClosed  Boolean @default(false)

  shop Shop @relation(fields: [shopId], references: [id])
}

// ══════════════════════════════════════════════════════════════
// AI-DRIVEN STOREFRONT
// ══════════════════════════════════════════════════════════════

model SellerStorefront {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  shopId        String    @unique @db.ObjectId
  config        Json      // StorefrontConfig as JSON
  published     Boolean   @default(false)
  publishedAt   DateTime?
  subdomain     String?   @unique // "myshop" → myshop.eseller.mn
  customDomain  String?   @unique // "myshop.mn"
  aiGeneratedAt DateTime?
  lastEditedAt  DateTime  @updatedAt
  createdAt     DateTime  @default(now())

  shop Shop @relation(fields: [shopId], references: [id])
}

// ══════════════════════════════════════════════════════════════
// MULTI-ENTITY — Agent, Company, AutoDealer, ServiceProvider
// ══════════════════════════════════════════════════════════════

model Agent {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique @db.ObjectId
  name          String
  slug          String   @unique
  profilePhoto  String?
  coverImage    String?
  bio           String?
  licenseNumber String?
  experience    Int?
  specialties   String[]
  phone         String?
  address       String?
  district      String?
  lat           Float?
  lng           Float?
  isVerified    Boolean  @default(false)
  rating        Float?
  reviewCount   Int?     @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User       @relation(fields: [userId], references: [id])
  listings FeedItem[]
}

model Company {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique @db.ObjectId
  name          String
  slug          String   @unique
  logo          String?
  coverImage    String?
  description   String?
  foundedYear   Int?
  employeeCount Int?
  licenseNumber String?
  awards        String[]
  socialLinks   Json?
  phone         String?
  address       String?
  district      String?
  lat           Float?
  lng           Float?
  isVerified    Boolean  @default(false)
  rating        Float?
  reviewCount   Int?     @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User       @relation(fields: [userId], references: [id])
  projects FeedItem[]
}

model AutoDealer {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @unique @db.ObjectId
  name        String
  slug        String   @unique
  logo        String?
  coverImage  String?
  description String?
  brands      String[]
  phone       String?
  address     String?
  district    String?
  lat         Float?
  lng         Float?
  isVerified  Boolean  @default(false)
  rating      Float?
  reviewCount Int?     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User       @relation(fields: [userId], references: [id])
  vehicles FeedItem[]
}

model ServiceProvider {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @unique @db.ObjectId
  name         String
  slug         String   @unique
  logo         String?
  coverImage   String?
  description  String?
  serviceTypes String[]
  portfolio    String[]
  phone        String?
  address      String?
  district     String?
  lat          Float?
  lng          Float?
  isVerified   Boolean  @default(false)
  rating       Float?
  reviewCount  Int?     @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User       @relation(fields: [userId], references: [id])
  listings FeedItem[]
}

// ══════════════════════════════════════════════════════════════
// UNIFIED FEED — VIP / FEATURED / DISCOUNTED / NORMAL Tiers
// ══════════════════════════════════════════════════════════════

model FeedItem {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  refId         String    @unique
  title         String
  description   String?
  price         Float?
  originalPrice Float?
  images        String[]
  category      String?
  subcategory   String?
  entityType    String    // store | agent | company | auto_dealer | service | user
  entityId      String    @db.ObjectId
  tier          String    @default("normal") // vip | featured | discounted | normal
  status        String    @default("active") // active | pending | expired | suspended
  viewCount     Int       @default(0)
  district      String?
  province      String?
  lat           Float?
  lng           Float?
  metadata      Json?     // entity-specific: sqm, rooms, year, mileage, etc
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  expiresAt     DateTime?
  tierExpiresAt DateTime?

  agentId           String? @db.ObjectId
  companyId         String? @db.ObjectId
  autoDealerId      String? @db.ObjectId
  serviceProviderId String? @db.ObjectId

  // Partner & Affiliate
  allowAffiliate      Boolean @default(false)
  affiliateCommission Float?  @default(0)
  partnerId           String? @db.ObjectId
  partnerAgentId      String? @db.ObjectId
  isPartnerListing    Boolean @default(false)
  vatIncluded         Boolean @default(false)

  agent           Agent?           @relation(fields: [agentId], references: [id])
  company         Company?         @relation(fields: [companyId], references: [id])
  autoDealer      AutoDealer?      @relation(fields: [autoDealerId], references: [id])
  serviceProvider ServiceProvider? @relation(fields: [serviceProviderId], references: [id])
  partnerCompany  PartnerCompany?  @relation(fields: [partnerId], references: [id])
  partnerAgent    PartnerAgent?    @relation(fields: [partnerAgentId], references: [id])
  media           EntityMedia[]
}

// ══════════════════════════════════════════════════════════════
// МЕДИА СИСТЕМ
// ══════════════════════════════════════════════════════════════

model EntityMedia {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  feedItemId  String?  @db.ObjectId
  productId   String?  @db.ObjectId

  type        String   @default("IMAGE") // IMAGE | VIDEO | VIRTUAL_TOUR | FLOOR_PLAN
  url         String
  thumbnail   String?
  caption     String?
  sortOrder   Int      @default(0)
  duration    Int?

  createdAt   DateTime @default(now())

  feedItem    FeedItem? @relation(fields: [feedItemId], references: [id])

  @@map("entity_media")
}

// ══════════════════════════════════════════════════════════════
// ANALYTICS + REVIEWS + ORDER STATUS
// ══════════════════════════════════════════════════════════════

model OrderAnalytics {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  sellerId    String   @db.ObjectId
  date        DateTime
  revenue     Int
  orderCount  Int
  avgOrderVal Int
  topProducts Json
}

model Review {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  productId String   @db.ObjectId
  buyerId   String   @db.ObjectId
  orderId   String   @db.ObjectId
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
}

// ══════════════════════════════════════════════════════════════
// AFFILIATE SYSTEM
// ══════════════════════════════════════════════════════════════

model AffiliateLink {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  affiliateId String   @db.ObjectId
  productId   String   @db.ObjectId
  code        String   @unique
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())

  conversions AffiliateConversion[]
}

model AffiliateConversion {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  linkId     String   @db.ObjectId
  orderId    String   @db.ObjectId
  commission Int
  status     String   @default("pending") // pending | paid
  createdAt  DateTime @default(now())

  link AffiliateLink @relation(fields: [linkId], references: [id])
}

// ══════════════════════════════════════════════════════════════
// WISHLIST
// ══════════════════════════════════════════════════════════════

model WishlistItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  productId String   @db.ObjectId
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

// ══════════════════════════════════════════════════════════════
// PRE-ORDER SYSTEM
// ══════════════════════════════════════════════════════════════

model PreOrderProduct {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  entityId         String   @db.ObjectId
  refId            String   @unique
  name             String
  description      String?
  images           String[]
  emoji            String?
  sourceCountry    String
  priceEstimate    Float
  priceFinal       Float?
  advancePct       Int      @default(30)
  minOrderQty      Int      @default(1)
  maxOrderQty      Int?
  deliveryDays     Int
  deliveryDaysMax  Int?
  status           String   @default("OPEN") // DRAFT|OPEN|BATCH_FULL|ORDERED|IN_TRANSIT|CUSTOMS|ARRIVED|DELIVERING|COMPLETED|CANCELLED
  batchDeadline    DateTime?
  currentOrders    Int      @default(0)
  targetOrders     Int?
  shippingTracking String?
  customsInfo      Json?
  category         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items   PreOrderItem[]
  batches PreOrderBatch[]
}

model PreOrderItem {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  productId       String    @db.ObjectId
  buyerId         String    @db.ObjectId
  quantity        Int
  unitPrice       Float
  advanceAmount   Float
  remainingAmount Float
  advancePaidAt   DateTime?
  finalPaidAt     DateTime?
  status          String    @default("PENDING") // PENDING|ADVANCE_PAID|IN_BATCH|SHIPPED|ARRIVED|FINAL_PAID|DELIVERED|CANCELLED
  notes           String?
  createdAt       DateTime  @default(now())

  product PreOrderProduct @relation(fields: [productId], references: [id])
}

model PreOrderBatch {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  productId    String    @db.ObjectId
  batchNumber  Int
  orderCount   Int
  totalQty     Int
  orderedAt    DateTime?
  eta          DateTime?
  trackingCode String?
  status       String    @default("COLLECTING") // COLLECTING|ORDERED|IN_TRANSIT|CUSTOMS|ARRIVED|DISTRIBUTED
  createdAt    DateTime  @default(now())

  product PreOrderProduct @relation(fields: [productId], references: [id])
}

// ══════════════════════════════════════════════════════════════
// BANNER MANAGEMENT SYSTEM
// ══════════════════════════════════════════════════════════════

model Banner {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  refId       String   @unique
  title       String
  slot        String   // HERO|ANNOUNCEMENT|MID_PAGE|IN_FEED|SIDEBAR_RIGHT|SECTION_SEPARATOR|CATEGORY_TOP|PRODUCT_BELOW
  imageUrl    String
  imageMobile String?
  linkUrl     String
  altText     String?
  bgColor     String?
  entityId    String?  @db.ObjectId
  entityName  String?
  status      String   @default("DRAFT") // DRAFT|PENDING|SCHEDULED|ACTIVE|PAUSED|EXPIRED|REJECTED
  startsAt    DateTime
  endsAt      DateTime
  sortOrder   Int      @default(0)
  isPaid      Boolean  @default(false)
  planId      String?  @db.ObjectId
  paymentId   String?
  price       Float?
  impressions Int      @default(0)
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?  @db.ObjectId
  analytics   BannerAnalytic[]
}

model BannerPlan {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  slot         String
  durationDays Int
  price        Float
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  maxPerPeriod Int?
  description  String?
  features     String[]
  createdAt    DateTime @default(now())
}

model BannerAnalytic {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  bannerId    String   @db.ObjectId
  date        DateTime
  impressions Int      @default(0)
  clicks      Int      @default(0)
  ctr         Float?
  banner      Banner   @relation(fields: [bannerId], references: [id])
  @@unique([bannerId, date])
}

model Announcement {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  text      String
  icon      String?
  linkUrl   String?
  isActive  Boolean   @default(true)
  sortOrder Int       @default(0)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
}

// ══════════════════════════════════════════════════════════════
// MARKETING AUTOMATION SYSTEM
// ══════════════════════════════════════════════════════════════

model Campaign {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  refId         String   @unique
  name          String
  type          String   // SMS|EMAIL|PUSH|MULTI_CHANNEL
  status        String   @default("DRAFT") // DRAFT|SCHEDULED|SENDING|SENT|PAUSED|CANCELLED|FAILED
  entityId      String?  @db.ObjectId
  createdById   String   @db.ObjectId
  subject       String?
  previewText   String?
  smsText       String?
  emailHtml     String?
  emailJson     Json?
  pushTitle     String?
  pushBody      String?
  audienceType  String   @default("ALL") // ALL|SEGMENT|MANUAL_LIST|CART_ABANDONERS|WISHLIST|INACTIVE
  segmentId     String?  @db.ObjectId
  audienceCount Int      @default(0)
  scheduledAt   DateTime?
  sentAt        DateTime?
  completedAt   DateTime?
  totalSent     Int      @default(0)
  delivered     Int      @default(0)
  opened        Int      @default(0)
  clicked       Int      @default(0)
  bounced       Int      @default(0)
  unsubscribed  Int      @default(0)
  converted     Int      @default(0)
  revenue       Float    @default(0)
  estimatedCost Float?
  actualCost    Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  sends         CampaignSend[]
  events        CampaignEvent[]
}

model AutomationFlow {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  trigger       String     // CART_ABANDONED|ORDER_PLACED|ORDER_DELIVERED|FIRST_PURCHASE|WISHLIST_PRICE_DROP|USER_REGISTERED|USER_INACTIVE|MANUAL
