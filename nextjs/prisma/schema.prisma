// ══════════════════════════════════════════════════════════════
// CHAT / MESSAGING SYSTEM
// ══════════════════════════════════════════════════════════════

model Conversation {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  shopId       String   @db.ObjectId          // Дэлгүүрийн ID
  customerId   String   @db.ObjectId          // Хэрэглэгчийн User ID
  customerName String                         // Хэрэглэгчийн нэр (cache)

  // Холбоос
  orderId      String?  @db.ObjectId          // Захиалгатай холбоотой бол
  orderNumber  String?                        // "#1042"
  productName  String?                        // Барааны нэр (reference)
  productPrice Int?                           // Барааны үнэ

  // Статус
  status       String   @default("active")    // active | archived | blocked
  tag          String?                        // order | question | complaint
  lastMessage  String?                        // Сүүлийн мессеж (preview)
  lastAt       DateTime @default(now())       // Сүүлийн мессеж огноо

  // Уншаагүй тоо (seller талаас)
  unreadCount  Int      @default(0)

  messages     Message[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Message {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  conversationId String   @db.ObjectId
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  senderId       String   @db.ObjectId        // User ID
  senderRole     String                       // "customer" | "seller"
  text           String?
  imageUrl       String?

  isRead         Boolean  @default(false)
  readAt         DateTime?

  createdAt      DateTime @default(now())
}

