// ══════════════════════════════════════════════════════════════
// eseller.mn — Prisma Schema (MongoDB)
// ══════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ══════════════════════════════════════════════════════════════
// EXISTING MODELS (migrated from Mongoose)
// ══════════════════════════════════════════════════════════════

type StoreInfo {
  name        String?
  description String?
  logo        String?
  phone       String?
  address     String?
  commission  Int?    @default(15)
}

type AffiliateInfo {
  bio       String?
  avatar    String?
  cover     String?
  verified  Boolean? @default(false)
  followers Int?     @default(0)
}

type BankInfo {
  bankName      String?
  accountNumber String?
  accountName   String?
}

model User {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String    @unique
  password  String
  role      String    @default("buyer") // buyer | seller | affiliate | delivery | admin
  username  String?   @unique
  phone     String?
  avatar    String?
  store     StoreInfo?
  affiliate AffiliateInfo?
  bankInfo  BankInfo?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  entityType String?  // store | agent | company | auto_dealer | service

  // Relations
  products  Product[]
  orders    Order[]
  wallet    Wallet?
  shop      Shop?
  agent     Agent?
  company   Company?
  autoDealer AutoDealer?
  serviceProvider ServiceProvider?
}

model Product {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  name          String
  price         Int
  salePrice     Int?
  description   String?
  category      String?
  emoji         String?
  images        String[]
  stock         Int?     @default(0)
  commission    Int?     @default(15)
  rating        Float?
  reviewCount   Int?     @default(0)
  isActive      Boolean  @default(true)
  deliveryFee   Int?
  deliveryType  String   @default("standard") // standard | express | pickup
  estimatedMins Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id])
  modifierGroups ModifierGroup[]
  addOns         AddOn[]
  reviews        Review[]
}

model ModifierGroup {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  productId String           @db.ObjectId
  name      String
  required  Boolean          @default(false)
  multiple  Boolean          @default(false)
  sortOrder Int              @default(0)

  product Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  options ModifierOption[]
}

model ModifierOption {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  groupId   String  @db.ObjectId
  name      String
  price     Int     @default(0)
  available Boolean @default(true)
  sortOrder Int     @default(0)

  group ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model AddOn {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  productId String  @db.ObjectId
  name      String
  price     Int
  image     String?
  available Boolean @default(true)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

type DeliveryAddress {
  district String?
  street   String?
  building String?
}

type DeliveryInfo {
  phone   String?
  address DeliveryAddress?
}

type OrderCommissions {
  affiliate Float?
}

model Order {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  userId       String           @db.ObjectId
  orderNumber  String?
  items        Json[]
  total        Float?
  status           String           @default("pending") // pending | confirmed | preparing | ready | delivering | delivered | cancelled
  referralCode     String?
  delivery         DeliveryInfo?
  commissions      OrderCommissions?
  statusHistory    Json[]
  estimatedMinutes Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Wallet {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  balance   Float    @default(0)
  pending   Float    @default(0)
  history   Json[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Commission {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  defaultRate Float @default(15)
  categories  Json?
}

model AffiliateClick {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  referralCode String
  page         String?
  timestamp    DateTime @default(now())
}

// ══════════════════════════════════════════════════════════════
// NEW MODELS — Service Business Support
// ══════════════════════════════════════════════════════════════

model Shop {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  name      String
  slug      String   @unique
  logo      String?
  phone     String?
  address   String?
  industry  String?
  // Location
  lat           Float?
  lng           Float?
  district      String?  // Дүүрэг: СБД, ЧД, БЗД, ХУД, СХД, БГД, НД
  khoroo        String?  // Хороо: 1-р хороо, 2-р хороо
  locationNote  String?  // Ойролцоох газар
  locationStatus String  @default("pending") // pending | verified | rejected
  locationVerifiedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User               @relation(fields: [userId], references: [id])
  shopType     ShopType?
  services     Service[]
  bookings     Booking[]
  shopDomain   ShopDomain?
  workingHours WorkingHours[]
  storefront   SellerStorefront?
}

model ShopType {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  shopId String @unique @db.ObjectId
  type   String // "product" | "service" | "hybrid"

  shop Shop @relation(fields: [shopId], references: [id])
}

model Service {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  shopId      String   @db.ObjectId
  name        String
  description String?
  price       Int
  duration    Int?     // minutes
  category    String?
  images      String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop     Shop      @relation(fields: [shopId], references: [id])
  bookings Booking[]
}

model Booking {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  serviceId     String   @db.ObjectId
  shopId        String   @db.ObjectId
  customerId    String?  @db.ObjectId
  customerName  String
  customerPhone String
  scheduledAt   DateTime
  duration      Int?     // minutes — copied from service at booking time
  status        String   @default("pending") // pending | confirmed | in_progress | completed | cancelled | no_show
  notes         String?
  total         Int?
  createdAt     DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id])
  shop    Shop    @relation(fields: [shopId], references: [id])
}

model ShopDomain {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  shopId    String   @unique @db.ObjectId
  domain    String   @unique // e.g. "hairsalon.mn"
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id])
}

model WorkingHours {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  shopId    String  @db.ObjectId
  dayOfWeek Int     // 0=Sun, 1=Mon ... 6=Sat
  openTime  String  // "09:00"
  closeTime String  // "18:00"
  isClosed  Boolean @default(false)

  shop Shop @relation(fields: [shopId], references: [id])
}

// ══════════════════════════════════════════════════════════════
// AI-DRIVEN STOREFRONT
// ══════════════════════════════════════════════════════════════

model SellerStorefront {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  shopId        String    @unique @db.ObjectId
  config        Json      // StorefrontConfig as JSON
  published     Boolean   @default(false)
  publishedAt   DateTime?
  subdomain     String?   @unique // "myshop" → myshop.eseller.mn
  customDomain  String?   @unique // "myshop.mn"
  aiGeneratedAt DateTime?
  lastEditedAt  DateTime  @updatedAt
  createdAt     DateTime  @default(now())

  shop Shop @relation(fields: [shopId], references: [id])
}

// ══════════════════════════════════════════════════════════════
// MULTI-ENTITY — Agent, Company, AutoDealer, ServiceProvider
// ══════════════════════════════════════════════════════════════

model Agent {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique @db.ObjectId
  name          String
  slug          String   @unique
  profilePhoto  String?
  coverImage    String?
  bio           String?
  licenseNumber String?
  experience    Int?
  specialties   String[]
  phone         String?
  address       String?
  district      String?
  lat           Float?
  lng           Float?
  isVerified    Boolean  @default(false)
  rating        Float?
  reviewCount   Int?     @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User       @relation(fields: [userId], references: [id])
  listings FeedItem[]
}

model Company {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique @db.ObjectId
  name          String
  slug          String   @unique
  logo          String?
  coverImage    String?
  description   String?
  foundedYear   Int?
  employeeCount Int?
  licenseNumber String?
  awards        String[]
  socialLinks   Json?
  phone         String?
  address       String?
  district      String?
  lat           Float?
  lng           Float?
  isVerified    Boolean  @default(false)
  rating        Float?
  reviewCount   Int?     @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User       @relation(fields: [userId], references: [id])
  projects FeedItem[]
}

model AutoDealer {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @unique @db.ObjectId
  name        String
  slug        String   @unique
  logo        String?
  coverImage  String?
  description String?
  brands      String[]
  phone       String?
  address     String?
  district    String?
  lat         Float?
  lng         Float?
  isVerified  Boolean  @default(false)
  rating      Float?
  reviewCount Int?     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User       @relation(fields: [userId], references: [id])
  vehicles FeedItem[]
}

model ServiceProvider {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @unique @db.ObjectId
  name         String
  slug         String   @unique
  logo         String?
  coverImage   String?
  description  String?
  serviceTypes String[]
  portfolio    String[]
  phone        String?
  address      String?
  district     String?
  lat          Float?
  lng          Float?
  isVerified   Boolean  @default(false)
  rating       Float?
  reviewCount  Int?     @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User       @relation(fields: [userId], references: [id])
  listings FeedItem[]
}

// ══════════════════════════════════════════════════════════════
// UNIFIED FEED — VIP / FEATURED / DISCOUNTED / NORMAL Tiers
// ══════════════════════════════════════════════════════════════

model FeedItem {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  refId         String    @unique
  title         String
  description   String?
  price         Float?
  originalPrice Float?
  images        String[]
  category      String?
  subcategory   String?
  entityType    String    // store | agent | company | auto_dealer | service | user
  entityId      String    @db.ObjectId
  tier          String    @default("normal") // vip | featured | discounted | normal
  status        String    @default("active") // active | pending | expired | suspended
  viewCount     Int       @default(0)
  district      String?
  lat           Float?
  lng           Float?
  metadata      Json?     // entity-specific: sqm, rooms, year, mileage, etc
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  expiresAt     DateTime?
  tierExpiresAt DateTime?

  agentId           String? @db.ObjectId
  companyId         String? @db.ObjectId
  autoDealerId      String? @db.ObjectId
  serviceProviderId String? @db.ObjectId

  agent           Agent?           @relation(fields: [agentId], references: [id])
  company         Company?         @relation(fields: [companyId], references: [id])
  autoDealer      AutoDealer?      @relation(fields: [autoDealerId], references: [id])
  serviceProvider ServiceProvider? @relation(fields: [serviceProviderId], references: [id])
}

// ══════════════════════════════════════════════════════════════
// ANALYTICS + REVIEWS + ORDER STATUS
// ══════════════════════════════════════════════════════════════

model OrderAnalytics {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  sellerId    String   @db.ObjectId
  date        DateTime
  revenue     Int
  orderCount  Int
  avgOrderVal Int
  topProducts Json
}

model Review {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  productId String   @db.ObjectId
  buyerId   String   @db.ObjectId
  orderId   String   @db.ObjectId
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
}

// ══════════════════════════════════════════════════════════════
// AFFILIATE SYSTEM
// ══════════════════════════════════════════════════════════════

model AffiliateLink {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  affiliateId String   @db.ObjectId
  productId   String   @db.ObjectId
  code        String   @unique
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())

  conversions AffiliateConversion[]
}

model AffiliateConversion {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  linkId     String   @db.ObjectId
  orderId    String   @db.ObjectId
  commission Int
  status     String   @default("pending") // pending | paid
  createdAt  DateTime @default(now())

  link AffiliateLink @relation(fields: [linkId], references: [id])
}
