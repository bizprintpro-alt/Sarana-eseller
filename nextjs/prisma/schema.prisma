  userId      String    @db.ObjectId
  channel     String
  recipient   String
  status      String    @default("pending")
  sentAt      DateTime?
  deliveredAt DateTime?
  errorMsg    String?
  messageId   String?
  campaign    Campaign  @relation(fields: [campaignId], references: [id])
