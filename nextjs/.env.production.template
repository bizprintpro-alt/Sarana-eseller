# ═══════════════════════════════════════════════════════
# eseller.mn — Production Environment Variables
# Copy to Vercel Environment Variables dashboard
# ═══════════════════════════════════════════════════════

# ── Database ──
DATABASE_URL="mongodb+srv://user:pass@cluster.mongodb.net/eseller_prod"

# ── Auth ──
JWT_SECRET="CHANGE_TO_RANDOM_64_CHAR_STRING"
NEXTAUTH_SECRET="CHANGE_TO_RANDOM_64_CHAR_STRING"

# ── URLs ──
NEXT_PUBLIC_URL="https://eseller.mn"
NEXT_PUBLIC_API_URL="https://eseller.mn/api"

# ── QPay (merchant.qpay.mn-ээс авна) ──
QPAY_USERNAME="your_qpay_username"
QPAY_PASSWORD="your_qpay_password"
QPAY_INVOICE_CODE="ESELLER_MN"
QPAY_URL="https://merchant.qpay.mn/v2"
QPAY_CALLBACK_SECRET="CHANGE_TO_RANDOM_32_CHAR_STRING"

# ── Sentry ──
SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
SENTRY_AUTH_TOKEN="sntrys_xxx"

# ── Email (Resend) ──
RESEND_API_KEY="re_xxx"
EMAIL_FROM="eseller.mn <noreply@eseller.mn>"

# ── SMS (Unitel) ──
UNITEL_SMS_URL="https://sms.unitel.mn/api/v1"
UNITEL_SMS_KEY="your_unitel_key"

# ── Cloudinary ──
CLOUDINARY_CLOUD_NAME="your_cloud"
CLOUDINARY_API_KEY="xxx"
CLOUDINARY_API_SECRET="xxx"

# ── Google ──
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
GOOGLE_MAPS_API_KEY="xxx"

# ── Dropshipping (RapidAPI + CJ + AliExpress) ──
# Used by /api/dropship/search and /api/dropship/fulfill. If these are
# missing, `/dropship/search` falls back to demo data (8 fake products
# with `demo: true` in the response) and CJ order placement no-ops.
# RapidAPI: aliexpress-datahub host for product search
RAPIDAPI_KEY="your_rapidapi_key"
# CJ Dropshipping — email+password used to fetch an access token per
# request in the search route; the long-lived CJ_ACCESS_TOKEN is used
# by the direct REST client in src/lib/aliexpress.ts.
CJ_EMAIL="your_cj_email"
CJ_PASSWORD="your_cj_password"
CJ_ACCESS_TOKEN="your_cj_access_token"
# AliExpress Affiliate API (optional — only if using the native client
# in src/lib/aliexpress.ts instead of the RapidAPI bridge).
ALIEXPRESS_APP_KEY="your_aliexpress_app_key"
ALIEXPRESS_APP_SECRET="your_aliexpress_app_secret"

# ── Claude AI ──
ANTHROPIC_API_KEY="sk-ant-xxx"

# ── Cron ──
CRON_SECRET="CHANGE_TO_RANDOM_32_CHAR_STRING"

# ── Middleware ──
MIDDLEWARE_SECRET="CHANGE_TO_RANDOM_32_CHAR_STRING"
