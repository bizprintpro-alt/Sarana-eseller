PORT=5000
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/eseller
JWT_SECRET=your_jwt_secret_here_min_32_chars

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
