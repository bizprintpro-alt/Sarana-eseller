// ══════════════════════════════════════════════════════════════
// eseller.mn — Prisma Schema (MongoDB)
// ══════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ══════════════════════════════════════════════════════════════
// EXISTING MODELS (migrated from Mongoose)
// ══════════════════════════════════════════════════════════════

type StoreInfo {
  name        String?
  description String?
  logo        String?
  phone       String?
  address     String?
  commission  Int?    @default(15)
}

type AffiliateInfo {
  bio       String?
  avatar    String?
  cover     String?
  verified  Boolean? @default(false)
  followers Int?     @default(0)
}

type BankInfo {
  bankName      String?
  accountNumber String?
  accountName   String?
}

model User {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String    @unique
  password  String
  role      String    @default("buyer") // buyer | seller | affiliate | delivery | admin
  username  String?   @unique
  phone     String?
  avatar    String?
  store     StoreInfo?
  affiliate AffiliateInfo?
  bankInfo  BankInfo?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  products  Product[]
  orders    Order[]
  wallet    Wallet?
  shop      Shop?
}

model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  name        String
  price       Int
  salePrice   Int?
  description String?
  category    String?
  emoji       String?
  images      String[]
  stock       Int?     @default(0)
  commission  Int?     @default(15)
  rating      Float?
  reviewCount Int?     @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

type DeliveryAddress {
  district String?
  street   String?
  building String?
}

type DeliveryInfo {
  phone   String?
  address DeliveryAddress?
}

type OrderCommissions {
  affiliate Float?
}

model Order {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  userId       String           @db.ObjectId
  orderNumber  String?
  items        Json[]
  total        Float?
  status       String           @default("pending") // pending | confirmed | shipped | delivered | cancelled
  referralCode String?
  delivery     DeliveryInfo?
  commissions  OrderCommissions?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Wallet {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  balance   Float    @default(0)
  pending   Float    @default(0)
  history   Json[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Commission {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  defaultRate Float @default(15)
  categories  Json?
}

model AffiliateClick {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  referralCode String
  page         String?
  timestamp    DateTime @default(now())
}

// ══════════════════════════════════════════════════════════════
// NEW MODELS — Service Business Support
// ══════════════════════════════════════════════════════════════

model Shop {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  name      String
  slug      String   @unique
  logo      String?
  phone     String?
  address   String?
  industry  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  shopType     ShopType?
  services     Service[]
  bookings     Booking[]
  shopDomain   ShopDomain?
  workingHours WorkingHours[]
}

model ShopType {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  shopId String @unique @db.ObjectId
  type   String // "product" | "service" | "hybrid"

  shop Shop @relation(fields: [shopId], references: [id])
}

model Service {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  shopId      String   @db.ObjectId
  name        String
  description String?
  price       Int
  duration    Int?     // minutes
  category    String?
  images      String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop     Shop      @relation(fields: [shopId], references: [id])
  bookings Booking[]
}

model Booking {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  serviceId     String   @db.ObjectId
  shopId        String   @db.ObjectId
  customerId    String?  @db.ObjectId
  customerName  String
  customerPhone String
  scheduledAt   DateTime
  duration      Int?     // minutes — copied from service at booking time
  status        String   @default("pending") // pending | confirmed | in_progress | completed | cancelled | no_show
  notes         String?
  total         Int?
  createdAt     DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id])
  shop    Shop    @relation(fields: [shopId], references: [id])
}

model ShopDomain {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  shopId    String   @unique @db.ObjectId
  domain    String   @unique // e.g. "hairsalon.mn"
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id])
}

model WorkingHours {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  shopId    String  @db.ObjectId
  dayOfWeek Int     // 0=Sun, 1=Mon ... 6=Sat
  openTime  String  // "09:00"
  closeTime String  // "18:00"
  isClosed  Boolean @default(false)

  shop Shop @relation(fields: [shopId], references: [id])
}
